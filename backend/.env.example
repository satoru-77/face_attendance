SECRET_KEY=django-insecure-change-this-to-a-long-random-string-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
DB_NAME=face_attendance_db
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Media files directory (relative to backend/)
MEDIA_ROOT=media/

# InsightFace model — buffalo_l downloads automatically (~500MB on first run)
INSIGHTFACE_MODEL=buffalo_l
